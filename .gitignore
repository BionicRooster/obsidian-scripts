# Ignore everything by default
*

# Track PowerShell scripts
!*.ps1

# Track Python scripts
!*.py

# Track batch files
!*.bat

# Track dashboard
!dashboard.html

# Don't track log files
*.log
*.txt

# Track gitignore itself
!.gitignore

# Track Claude config and skill commands
!.claude/
!.claude/commands/
!.claude/commands/*.md

# Track Claude memory files
!.claude/projects/
!.claude/projects/C--Users-awt/
!.claude/projects/C--Users-awt/memory/
!.claude/projects/C--Users-awt/memory/*.md
